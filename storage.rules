rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@fcbguwahati.com';
    }

    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /screenshots/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
